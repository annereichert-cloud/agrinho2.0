{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "server.js": {
      "includeFiles": "{index.html,manifest.webmanifest,sw.js,favicon.ico,assets/**,css/**,js/**,pages/**,prompts/**}"
    }
  },
  "rewrites": [
    {
      "source": "/app",
      "destination": "/pages/app.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/prompts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
